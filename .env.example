# Copy to .env (gitignored) and fill in real values.
# Neon URLs: copy BOTH from neon.tech dashboard. Pooled is default; toggle off for direct.
DATABASE_URL=postgresql://user:password@ep-XXXX-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_DIRECT=postgresql://user:password@ep-XXXX.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
ENV=dev
LOG_LEVEL=INFO
